# HIMS Frontend — LOCAL TESTING environment
# Copy to .env.local — NEVER commit .env.local to git.

# Points at the local backend started from backendLocalHost.zip.
# https:// is REQUIRED — himsApi.js throws a hard runtime error on http://
# or a missing value. This is a locked decision, not a local-only exception.
VITE_API_URL=https://localhost:8000
