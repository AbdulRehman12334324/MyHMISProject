{
  "name": "hims-intake-form",
  "version": "2.3.0",
  "private": true,
  "description": "HIMS Patient Intake Form — v2.3: Password reset flow + PII migration script",
  "type": "module",
  "scripts": {
    "dev":     "vite",
    "build":   "vite build",
    "preview": "vite preview",
    "lint":    "eslint src --ext js,jsx --report-unused-disable-directives",
    "audit":   "npm audit --audit-level=moderate",
    "test":    "vitest run --reporter=verbose",
    "ci":      "npm ci && npm audit --audit-level=moderate && npm run build"
  },
  "dependencies": {
    "react":     "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react":         "18.3.1",
    "@types/react-dom":     "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "eslint":               "9.13.0",
    "vite":                 "5.4.10",
    "terser":               "5.36.0",
    "vitest":               "2.1.8",
    "@testing-library/react":      "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@testing-library/jest-dom":   "6.6.3",
    "jsdom":                "25.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  }
}
